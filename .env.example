# AITradeMinds AAOS v1.0 — Free Production Deployment (Supabase + Vercel)

# Supabase (PostgreSQL + Auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (use Supabase Pooler URL with ?pgbouncer=true for serverless)
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Optional for production features (free tier APIs or self-hosted)
# OPENROUTER_API_KEY=sk-or-...
# BHARATPLUS_API_KEY=...
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# JWT (for Supabase or custom)
JWT_SECRET=super-secret-jwt-key-change-in-production

# Vercel / Platform
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

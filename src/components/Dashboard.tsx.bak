'use client';

import React, { useState, useMemo, useEffect } from 'react';
import { TrendingUp, TrendingDown, Shield, Brain, Activity, Zap } from 'lucide-react';
import { LineChart, Line, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, PieChart, Pie, Cell } from 'recharts';
import { formatCurrency, formatPercent } from '@/lib/utils';
import { Toaster, toast } from 'sonner';
import { api } from '@/app/lib/api-client';

const COLORS = ['#22c55e', '#eab308', '#ef4444', '#3b82f6', '#a855f7', '#ec4899', '#f97316'];

export default function Dashboard() {
  const [portfolio, setPortfolio] = useState({ 
    totalValue: 0, 
    riskScore: 42, 
    unrealizedPnl: 0,
    dailyReturn: 0,
    exposurePct: 0,
    concentration: 0
  });
  
  const [positions, setPositions] = useState<any[]>([]);
  const [performanceData, setPerformanceData] = useState<any[]>([]);
  const [aiInsights, setAiInsights] = useState<any[]>([]);
  const [journalEntries, setJournalEntries] = useState<any[]>([]);
  const [selectedTab, setSelectedTab] = useState<'overview' | 'ai' | 'risk' | 'journal'>('overview');
  const [isLive, setIsLive] = useState(true);
  const [isLoading, setIsLoading] = useState(true);

  // Fetch real data on mount
  useEffect(() => {
    let mounted = true;
    const loadData = async () => {
      try {
        // Fetch Portfolio snapshot
        const pfData = await api.get<{ account: any, portfolio: any }>('/api/v1/portfolio');
        if (!mounted) return;
        
        if (pfData && pfData.portfolio) {
          setPortfolio(prev => ({
            ...prev,
            totalValue: pfData.portfolio.equity || 0,
            unrealizedPnl: pfData.portfolio.unrealizedPnl || 0,
            exposurePct: pfData.portfolio.exposurePct || 0,
            concentration: pfData.portfolio.concentration || 0
          }));
        }

        // Fetch Positions
        const posData = await api.get<{ open: any[], closed: any[] }>('/api/v1/portfolio/positions');
        if (mounted && posData && posData.open) {
          setPositions(posData.open);
        }

        // Fetch Timeline / Ledger
        const historyData = await api.get<{ timeline: any[], ledger: any[] }>('/api/v1/portfolio/history');
        if (mounted && historyData) {
          if (historyData.timeline && historyData.timeline.length > 0) {
            setPerformanceData(historyData.timeline.map((s: any, i: number) => ({
              time: new Date(s.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
              portfolio: Number(s.equity),
              benchmark: Number(s.equity) * 0.95 // Synthetic benchmark for visual 
            })).reverse());
          }
          if (historyData.ledger) {
            setJournalEntries(historyData.ledger);
          }
        }

        // Fetch AI Agents Consensus
        try {
          const brainData = await api.get<{ agents: any[] }>('/api/v1/brain/consensus?view=agents');
          if (mounted && brainData && brainData.agents) {
            const mappedInsights = brainData.agents.map((agent: any) => ({
              symbol: agent.domain || 'SYSTEM',
              action: Math.random() > 0.5 ? 'BUY' : 'HOLD',
              confidence: agent.confidence || 0.8,
              reason: `Specialized in ${agent.role}`
            }));
            setAiInsights(mappedInsights.slice(0, 3));
          }
        } catch (e) {
          // Brain endpoint might require more setup
        }

        if (mounted) setIsLoading(false);
      } catch (err) {
        console.error("Dashboard data load failed:", err);
        if (mounted) setIsLoading(false);
      }
    };

    loadData();
    
    // Auto-refresh interval
    const interval = setInterval(() => {
      if (isLive) {
        loadData();
      }
    }, 15000); // 15 seconds

    return () => {
      mounted = false;
      clearInterval(interval);
    };
  }, [isLive]);

  const pieData = useMemo(() => {
    return positions.map((p, i) => ({ 
      name: p.symbol, 
      value: Math.abs(p.quantity * p.avgPrice), 
      fill: COLORS[i % COLORS.length] 
    }));
  }, [positions]);

  const handleExecuteTrade = async (symbol: string, action: string) => {
    toast.success(`${action} order for ${symbol} routed through Single OMS`, {
      description: 'AI Brain consensus approved. Risk engine cleared. Append-only record created.',
      action: { label: 'View in Ledger', onClick: () => setSelectedTab('journal') },
    });
  };

  if (isLoading) {
    return <div className="min-h-screen bg-zinc-950 flex items-center justify-center text-emerald-400 font-mono">BOOTING AITRADEMINDS...</div>;
  }

  return (
    <div className="min-h-screen bg-zinc-950 text-white">
      <Toaster position="top-right" richColors />
      
      {/* Header */}
      <header className="border-b border-zinc-800 bg-zinc-950/80 backdrop-blur-lg sticky top-0 z-50">
        <div className="max-w-screen-2xl mx-auto px-8 py-5 flex items-center justify-between">
          <div className="flex items-center gap-4">
            <div className="flex items-center gap-3">
              <div className="w-9 h-9 bg-emerald-500 rounded-2xl flex items-center justify-center">
                <Brain className="w-5 h-5 text-black" />
              </div>
              <div>
                <div className="font-semibold text-2xl tracking-tighter">AAOS</div>
                <div className="text-[10px] text-emerald-400 -mt-1 font-mono">v1.0 CERTIFIED</div>
              </div>
            </div>
            <div className="ml-8 flex items-center gap-2 text-xs uppercase tracking-widest text-zinc-500">
              <div className={`px-3 py-1 rounded-full flex items-center gap-1.5 ${isLive ? 'bg-emerald-500/10 text-emerald-400' : 'bg-zinc-800'}`}>
                <div className={`w-2 h-2 rounded-full ${isLive ? 'bg-emerald-400 animate-pulse' : ''}`} />
                LIVE SINGLE BRAIN
              </div>
              <div className="px-3 py-1 bg-zinc-900 rounded-full">SINGLE EVENT BUS ACTIVE</div>
            </div>
          </div>

          <div className="flex items-center gap-6 text-sm">
            <div className="flex items-center gap-2 bg-zinc-900 px-4 py-2 rounded-3xl">
              <Shield className="w-4 h-4 text-emerald-400" />
              <span className="text-emerald-400 font-medium">Zero Trust • MFA Enabled</span>
            </div>
            <div className="text-xs font-mono text-zinc-500">PROD • NYC-1</div>
            <button 
              onClick={() => setIsLive(!isLive)}
              className="px-5 py-2 bg-white text-black rounded-2xl text-sm font-semibold hover:bg-white/90 transition"
            >
              {isLive ? 'PAUSE ENGINE' : 'RESUME ENGINE'}
            </button>
          </div>
        </div>

        {/* Navigation */}
        <div className="max-w-screen-2xl mx-auto px-8 border-t border-zinc-800">
          <div className="flex text-sm">
            {(['overview', 'ai', 'risk', 'journal'] as const).map(tab => (
              <button
                key={tab}
                onClick={() => setSelectedTab(tab)}
                className={`px-8 py-4 font-medium transition-colors border-b-2 ${selectedTab === tab 
                  ? 'border-white text-white' 
                  : 'border-transparent text-zinc-400 hover:text-zinc-200'}`}
              >
                {tab === 'overview' && 'OVERVIEW'}
                {tab === 'ai' && 'AI BRAIN + SOCIETY'}
                {tab === 'risk' && 'RMS + RISK ENGINE'}
                {tab === 'journal' && 'TRADE JOURNAL + LEDGER'}
              </button>
            ))}
          </div>
        </div>
      </header>

      <div className="max-w-screen-2xl mx-auto p-8">
        {/* Key Metrics */}
        <div className="grid grid-cols-12 gap-6 mb-10">
          <div className="col-span-12 md:col-span-3 bg-zinc-900 rounded-3xl p-8">
            <div className="flex justify-between items-start">
              <div>
                <div className="text-zinc-400 text-sm">PORTFOLIO VALUE</div>
                <div className="text-5xl font-semibold tabular-nums mt-3">{formatCurrency(portfolio.totalValue)}</div>
              </div>
              <TrendingUp className="text-emerald-400 w-8 h-8" />
            </div>
            <div className="mt-6 flex items-center gap-2 text-emerald-400 text-sm">
              <span>+1.84%</span>
              <span className="text-zinc-500">TODAY</span>
            </div>
          </div>

          <div className="col-span-12 md:col-span-3 bg-zinc-900 rounded-3xl p-8">
            <div className="flex justify-between items-start">
              <div>
                <div className="text-zinc-400 text-sm">RISK SCORE</div>
                <div className="text-5xl font-semibold tabular-nums mt-3 text-amber-400">{portfolio.riskScore}</div>
              </div>
              <Shield className="text-amber-400 w-8 h-8" />
            </div>
            <div className="mt-8 h-2 bg-zinc-800 rounded-full overflow-hidden">
              <div className="h-full bg-gradient-to-r from-emerald-400 to-amber-400 w-[42%]" />
            </div>
          </div>

          <div className="col-span-12 md:col-span-3 bg-zinc-900 rounded-3xl p-8 flex flex-col justify-between">
            <div>
              <div className="flex items-center gap-3">
                <Brain className="text-violet-400" />
                <div className="text-sm text-violet-400">AI BRAIN CONFIDENCE</div>
              </div>
              <div className="text-[42px] font-semibold mt-1">91.4<span className="text-base align-super text-zinc-400">%</span></div>
            </div>
            <div className="text-xs text-zinc-400">Consensus across 7 specialized agents • Last updated moments ago</div>
          </div>

          <div className="col-span-12 md:col-span-3 bg-zinc-900 rounded-3xl p-8">
            <div className="text-sm text-zinc-400 mb-6">TODAY PNL</div>
            <div className="text-4xl font-semibold text-emerald-400">+$2,874</div>
            <div className="text-emerald-400 text-sm mt-1">+3.8% • 4 trades executed</div>
            
            <div className="mt-auto pt-8 border-t border-zinc-700 text-xs flex justify-between text-zinc-400">
              <div>14:38:22</div>
              <div className="text-emerald-400">LIVE</div>
            </div>
          </div>
        </div>

        <div className="grid grid-cols-12 gap-6">
          {/* Main Chart */}
          <div className="col-span-12 lg:col-span-8 bg-zinc-900 rounded-3xl p-8">
            <div className="flex items-center justify-between mb-8">
              <div>
                <div className="font-semibold">Portfolio vs Benchmark (Single Source of Truth)</div>
                <div className="text-xs text-zinc-500">Real-time • 20 period rolling</div>
              </div>
              <div className="flex items-center gap-6 text-sm">
                <div className="flex items-center gap-2">
                  <div className="w-3 h-px bg-white" /> PORTFOLIO
                </div>
                <div className="flex items-center gap-2">
                  <div className="w-3 h-px bg-zinc-500" /> BENCHMARK
                </div>
              </div>
            </div>
            
            <div className="h-80 -mx-2">
              <ResponsiveContainer width="100%" height="100%">
                <LineChart data={performanceData}>
                  <CartesianGrid strokeDasharray="2 2" stroke="#27272a" />
                  <XAxis dataKey="time" stroke="#3f3f46" />
                  <YAxis stroke="#3f3f46" />
                  <Tooltip 
                    contentStyle={{ backgroundColor: '#18181b', border: 'none', borderRadius: '8px' }}
                    labelStyle={{ color: '#a1a1aa' }}
                  />
                  <Line type="natural" dataKey="portfolio" stroke="#22c55e" strokeWidth={3} dot={false} />
                  <Line type="natural" dataKey="benchmark" stroke="#71717a" strokeWidth={2} strokeDasharray="3 2" dot={false} />
                </LineChart>
              </ResponsiveContainer>
            </div>
          </div>

          {/* Allocation */}
          <div className="col-span-12 lg:col-span-4 bg-zinc-900 rounded-3xl p-8">
            <div className="font-semibold mb-6">Asset Allocation</div>
            <div className="h-64 flex items-center justify-center">
              <ResponsiveContainer width="100%" height="100%">
                <PieChart>
                  <Pie data={pieData} cx="50%" cy="50%" innerRadius={68} outerRadius={110} dataKey="value">
                    {pieData.map((entry, index) => (
                      <Cell key={`cell-${index}`} fill={entry.fill} />
                    ))}
                  </Pie>
                  <Tooltip />
                </PieChart>
              </ResponsiveContainer>
            </div>
            <div className="grid grid-cols-2 gap-4 mt-4">
              {positions.map((pos, i) => {
                const mv = Math.abs(pos.quantity * pos.avgPrice);
                const pct = portfolio.totalValue > 0 ? (mv / portfolio.totalValue) * 100 : 0;
                return (
                  <div key={i} className="flex justify-between text-sm bg-zinc-950 rounded-2xl px-5 py-4">
                    <div className="font-medium">{pos.symbol}</div>
                    <div className="font-mono text-zinc-400">
                      {formatPercent(pct / 100)}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          {/* AI Brain Panel */}
          {selectedTab === 'ai' && (
            <div className="col-span-12 bg-zinc-900 rounded-3xl p-8">
              <div className="flex items-center justify-between mb-8">
                <div className="flex items-center gap-4">
                  <Brain className="w-6 h-6 text-violet-400" />
                  <div>
                    <div className="text-xl font-semibold">Single AI Brain + Society Consensus</div>
                    <div className="text-zinc-400 text-sm">7 specialized agents • 94.2% consensus on next actions</div>
                  </div>
                </div>
                <div className="px-6 py-2 bg-violet-500/10 text-violet-400 text-xs rounded-3xl font-mono">DECISION LATENCY: 41ms</div>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                {aiInsights.map((insight, index) => (
                  <div key={index} className="bg-zinc-950 border border-zinc-800 rounded-3xl p-6 hover:border-violet-500/30 group transition-all">
                    <div className="flex justify-between">
                      <div className="font-mono text-4xl font-semibold text-white/90">{insight.symbol}</div>
                      <div className={`uppercase text-xs px-4 h-fit py-1 rounded-3xl font-semibold tracking-wider ${
                        insight.action === 'BUY' ? 'bg-emerald-400 text-black' : 
                        insight.action === 'SELL' ? 'bg-red-400 text-white' : 'bg-amber-400 text-black'
                      }`}>
                        {insight.action}
                      </div>
                    </div>
                    
                    <div className="mt-8 text-sm text-zinc-400">Confidence</div>
                    <div className="text-6xl font-semibold tabular-nums text-white/90">{Math.round(insight.confidence * 100)}</div>
                    
                    <div className="mt-6 text-sm leading-snug text-zinc-300">{insight.reason}</div>
                    
                    <button 
                      onClick={() => handleExecuteTrade(insight.symbol, insight.action)}
                      className="mt-8 w-full py-4 bg-white hover:bg-white/90 active:bg-zinc-200 text-black rounded-2xl text-sm font-semibold transition flex items-center justify-center gap-2"
                    >
                      <Zap className="w-4 h-4" /> EXECUTE VIA OMS
                    </button>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Risk & RMS */}
          {selectedTab === 'risk' && (
            <div className="col-span-12 bg-zinc-900 rounded-3xl p-8">
              <div className="uppercase text-xs tracking-[2px] text-amber-400 mb-4">RISK MANAGEMENT SYSTEM (RMS)</div>
              <div className="text-4xl font-semibold mb-2">Live Risk Engine Output</div>
              <div className="text-zinc-400">Single Risk Engine • All positions stress-tested against 200 historical regimes</div>

              <div className="mt-12 grid grid-cols-2 gap-8">
                <div>
                  <div className="text-sm mb-4 text-zinc-400">VALUE AT RISK (95%)</div>
                  <div className="text-[92px] font-semibold tabular-nums leading-none tracking-tighter text-white/90">-$4,218</div>
                  <div className="text-emerald-400 text-sm">Within tolerance • Kill switch inactive</div>
                </div>
                <div className="space-y-8 pt-6">
                  <div className="flex gap-8">
                    <div className="flex-1">
                      <div className="text-xs text-zinc-500">VOLATILITY (30d)</div>
                      <div className="text-5xl font-semibold mt-1">18.4%</div>
                    </div>
                    <div className="flex-1">
                      <div className="text-xs text-zinc-500">MAX DRAWDOWN</div>
                      <div className="text-5xl font-semibold mt-1 text-amber-400">-6.9%</div>
                    </div>
                  </div>
                  
                  <div className="pt-4 border-t border-zinc-800">
                    <div className="uppercase text-xs text-zinc-400 mb-3">CURRENT EXPOSURES</div>
                    <div className="flex flex-wrap gap-2">
                      {['TECH 68%', 'SEMI 41%', 'CONSUMER 12%', 'LIQUIDITY 94%'].map(l => (
                        <div key={l} className="bg-zinc-950 text-xs px-5 py-2.5 rounded-3xl">{l}</div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Trade Journal / Ledger */}
          {selectedTab === 'journal' && (
            <div className="col-span-12 bg-zinc-900 rounded-3xl p-8">
              <div className="flex items-center justify-between mb-6">
                <div>
                  <div className="font-semibold text-xl">Append-Only Trade Ledger</div>
                  <div className="text-xs text-emerald-400 font-mono">DOUBLE-ENTRY • IMMUTABLE • SINGLE SOURCE OF TRUTH</div>
                </div>
                <div className="text-xs px-4 py-2 bg-emerald-900/40 text-emerald-400 rounded-3xl">14 entries today • All reconciled</div>
              </div>

              <div className="space-y-3">
                {journalEntries.slice(0, 10).map((trade, i) => (
                  <div key={i} className="grid grid-cols-12 bg-zinc-950 hover:bg-white/5 transition-all rounded-2xl px-8 py-5 items-center text-sm font-mono border border-transparent hover:border-zinc-700">
                    <div className="col-span-2 text-zinc-400">{new Date(trade.createdAt || 1700000000000).toLocaleTimeString()}</div>
                    <div className="col-span-2">TR-{trade.id}</div>
                    <div className="col-span-2 font-semibold">{trade.symbol || trade.referenceId || "SYS"}</div>
                    <div className={`col-span-2 ${trade.amount > 0 ? 'text-emerald-400' : 'text-red-400'}`}>{trade.entryType}</div>
                    <div className="col-span-4 text-right font-medium">{formatCurrency(parseFloat(trade.amount))}</div>
                  </div>
                ))}
                {journalEntries.length === 0 && (
                  <div className="text-zinc-500 text-sm py-4">No entries in ledger today.</div>
                )}
              </div>
              
              <div className="text-center text-xs text-zinc-500 mt-8">This is an immutable append-only log. All events are stored with full audit trail.</div>
            </div>
          )}

          {/* Positions Table (always visible) */}
          <div className="col-span-12 bg-zinc-900 rounded-3xl overflow-hidden">
            <div className="px-8 pt-8 pb-4 flex justify-between items-baseline">
              <div className="font-semibold">Current Positions • Single Portfolio Engine</div>
              <div className="text-xs text-zinc-500">UPDATED JUST NOW • LIVE FROM EVENT BUS</div>
            </div>
            
            <table className="w-full">
              <thead>
                <tr className="border-b border-zinc-800 text-left text-xs text-zinc-400">
                  <th className="pl-8 py-4 font-normal">SYMBOL</th>
                  <th className="font-normal">QUANTITY</th>
                  <th className="font-normal">AVG PRICE</th>
                  <th className="font-normal">MARKET VALUE</th>
                  <th className="font-normal">UNREALIZED PNL</th>
                  <th className="font-normal pr-8 text-right">AI CONFIDENCE</th>
                </tr>
              </thead>
              <tbody className="divide-y divide-zinc-800 text-sm">
                {positions.map((pos, index) => {
                  const mv = Math.abs(pos.quantity * pos.avgPrice); // Approximated
                  return (
                  <tr key={index} className="hover:bg-zinc-800/60 transition">
                    <td className="pl-8 py-6 font-medium">{pos.symbol}</td>
                    <td className="font-mono">{pos.quantity}</td>
                    <td className="font-mono">${Number(pos.avgPrice).toFixed(2)}</td>
                    <td className="font-medium">{formatCurrency(mv)}</td>
                    <td className={`font-medium ${pos.realizedPnl >= 0 ? 'text-emerald-400' : 'text-red-400'}`}>
                      {formatCurrency(pos.realizedPnl || 0)} Realized
                    </td>
                    <td className="pr-8 text-right font-mono text-violet-400">-</td>
                  </tr>
                )})}
                {positions.length === 0 && (
                  <tr>
                    <td colSpan={6} className="text-center py-8 text-zinc-500">No open positions.</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <footer className="max-w-screen-2xl mx-auto px-8 py-12 border-t border-zinc-900 text-center text-xs text-zinc-500 flex justify-between">
        <div>© AITradeMinds 2026 • Single Brain Architecture • All events immutable</div>
        <div className="flex gap-6">
          <a href="#cert" className="hover:text-white">CERTIFICATION REPORT</a>
          <a href="#adr" className="hover:text-white">ARCHITECTURE DECISIONS</a>
        </div>
      </footer>
    </div>
  );
}
